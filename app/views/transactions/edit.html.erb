<h1>Edit Transaction</h1>

<%= form_for @tx, html: { class: "edit-form" } do |form| %>
  <fieldset>
    <div class="form-group">
      <label>Date</label>
      <%= form.text_field :date %>
    </div>

    <div class="form-group">
      <label>Payee (friendly name)</label>
      <%= fields_for @tx.payee do |payee_fields| %>
        <%= payee_fields.text_field :friendly_name %>
      <% end %>
      <span class="form-note">Originally: <%= @tx.payee.name %></span>
    </div>

    <div class="form-group">
      <label>Amount</label>
      <%= form.text_field :amount %>
    </div>

    <div class="form-group">
      <label>Tags</label>
      <%= form.text_field :tag_list %>
    </div>

    <div class="form-actions">
      <%= form.submit "Save Changes" %>
      <%= link_to "Cancel", transactions_path %>
    </div>
  </fieldset>
<% end %>
