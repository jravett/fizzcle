
<h1>Listing Accounts</h1>
 
<div class="upload-form">
  <%= form_tag({:action => :upload}, :multipart => true) do %>
    <%= file_field_tag 'ofx_file' %>
    <%= submit_tag 'Upload' %>
  <% end %>
</div>

<table class="data-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Last Import Date</th>
      <th>Balance</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @accounts.each do |account| %>
      <tr>
        <td><%= account.name %></td>
        <td><%= account.last_import_date %></td>
        <td><%= number_to_currency(account.balance) %></td>
        <td><%= link_to 'Destroy', account_path(account),
                method: :delete,
                data: { confirm: 'Are you sure?' },
                class: 'danger-link' %></td>
      </tr>
    <% end %>
  </tbody>
</table>