<h1> Summary Report </h1>
<div class="filter-form">
  <%= form_tag :action=>'monthly_summary' do %>
    <%= select_month @start_date %>
    <%= select_year(@start_date, :start_year => (Date.today.year-3), :end_year => Date.today.year) %>
    <%= submit_tag 'change date' %>
  <% end %>
</div>

<table class="data-table">
  <thead>
    <tr>
      <th>Tag</th>
      <th>Amount</th>
    </tr>
  </thead>
  <tbody>
    <% @tag_amounts.each do |key, value| %>
      <tr>
        <td><%= key %></td>
        <td><%= number_to_currency(value) %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Reporting Home", { action: "index" }, class: "back-link" %>

