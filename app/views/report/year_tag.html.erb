<h1> Year Tag Report </h1>
<div class="filter-form">
  <%= form_tag :action=>'year_tag' do %>
    <%= text_field_tag :tag_name %>
    <%= select_year(@start_date, :start_year => (Date.today.year-3), :end_year => Date.today.year) %>
    <%= submit_tag 'get report' %>
  <% end %>
</div>

<% if @tag_name.present? %>
  <div class="report-summary">
    <span class="report-tag"><%= @tag_name %></span>
    <span class="report-total"><%= number_to_currency(@sum) %> total</span>
    <span class="report-count"><%= @count %> items</span>
  </div>
<% end %>

<% if @txs %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Payee</th>
        <th>Amount</th>
      </tr>
    </thead>
    <tbody>
      <% for tx in @txs %>
        <tr>
          <td><%= tx.date %></td>
          <td><%= tx.payee.friendly_name %></td>
          <td><%= number_to_currency(tx.amount) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<%= link_to "Reporting Home", { action: "index" }, class: "back-link" %>


