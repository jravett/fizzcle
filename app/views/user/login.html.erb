<div class="login-card">
  <%= form_tag('/user/login') do %>
    <div class="form-group">
      <%= label_tag 'login', 'User Name' %>
      <%= text_field_tag :login %>
    </div>
    <div class="form-group">
      <%= label_tag 'password', 'Password' %>
      <%= password_field_tag :password %>
    </div>
    <%= submit_tag 'Log In' %>
  <% end %>
</div>
